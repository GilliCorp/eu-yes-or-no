---
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const dossiers = (await getCollection('dossiers')).sort(
  (a, b) => a.data.order - b.data.order,
);

const dateFmt = new Intl.DateTimeFormat(lang === 'is' ? 'is-IS' : 'en-GB', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<div class="wrap">
  <section class="hero">
    <h1>{t(lang, 'site.title')}</h1>
    <p class="tagline">{t(lang, 'site.tagline')}</p>
    <p class="intro">{t(lang, 'home.intro')}</p>
    <p class="draft">{t(lang, 'home.draft')}</p>
  </section>

  <a class="start-here" href={getRelativeLocaleUrl(lang, 'start-here')}>
    <span class="sh-eyebrow">{t(lang, 'nav.startHere')} →</span>
    <span class="sh-title">{t(lang, 'home.startHere.title')}</span>
    <span class="sh-lead">{t(lang, 'home.startHere.lead')}</span>
  </a>

  <h2 class="section-label">{t(lang, 'home.chapters')}</h2>
  <ul class="chapters">
    {
      dossiers.map((d) => (
        <li>
          <a class="card" href={getRelativeLocaleUrl(lang, d.id)}>
            <span class="num">{String(d.data.order).padStart(2, '0')}</span>
            <span class="body">
              <span class="title">{d.data.title[lang]}</span>
              <span class="tldr">{d.data.tldr[lang]}</span>
              <span class="row">
                <span class="meta">
                  {t(lang, 'home.lastReviewed')}: {dateFmt.format(d.data.lastReviewed)}
                </span>
                <span class="go">{t(lang, 'home.readMore')} →</span>
              </span>
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .wrap { max-width: 50rem; margin: 0 auto; padding: clamp(2.5rem, 7vw, 5rem) clamp(1rem, 5vw, 2.5rem) 4rem; }

  .hero { margin-bottom: 3.5rem; }
  h1 { font-size: clamp(2.6rem, 8vw, 4.5rem); margin: 0 0 0.75rem; }
  .tagline {
    font-family: var(--display); font-weight: 500; font-size: clamp(1.2rem, 3vw, 1.6rem);
    line-height: 1.3; color: var(--ink); margin: 0 0 1.5rem; max-width: 32rem;
  }
  .intro { font-size: 1.125rem; color: #34322d; margin: 0 0 1.5rem; max-width: 38rem; }
  .draft {
    display: inline-block; font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.04em;
    color: #7a5a1e; background: #f4e9cf; border: 1px solid #e2cf9c; padding: 0.25rem 0.65rem; border-radius: 2px;
  }

  .start-here {
    display: block; text-decoration: none; color: inherit;
    border: 1px solid var(--line-strong); border-left: 4px solid var(--brass);
    background: var(--paper-raised); border-radius: 4px;
    padding: 1.25rem clamp(1rem, 3vw, 1.6rem); margin: 0 0 2.5rem;
    transition: border-color 0.15s;
  }
  .start-here:hover { border-color: var(--slate); }
  .sh-eyebrow {
    display: block; font-family: var(--mono); font-size: 0.72rem; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--brass); margin-bottom: 0.4rem;
  }
  .sh-title { display: block; font-family: var(--display); font-weight: 600; font-size: 1.2rem; margin-bottom: 0.3rem; }
  .sh-lead { display: block; color: #34322d; font-size: 1rem; }

  .section-label {
    font-family: var(--mono); font-size: 0.78rem; font-weight: 500; text-transform: uppercase;
    letter-spacing: 0.14em; color: var(--muted); margin: 0 0 0.5rem; border-bottom: 1px solid var(--line-strong);
    padding-bottom: 0.75rem;
  }

  .chapters { list-style: none; padding: 0; margin: 0; }
  .chapters li { border-bottom: 1px solid var(--line); }

  .card {
    display: flex; gap: clamp(0.85rem, 3vw, 1.5rem); padding: 1.5rem 0.5rem; text-decoration: none;
    color: inherit; transition: background 0.15s ease, padding 0.15s ease;
  }
  .card:hover { background: var(--paper-raised); padding-left: 1rem; padding-right: 1rem; }

  .num {
    font-family: var(--mono); font-variant-numeric: tabular-nums; font-size: 1rem; font-weight: 500;
    color: var(--brass); padding-top: 0.35rem; min-width: 1.6rem;
  }
  .body { display: flex; flex-direction: column; gap: 0.4rem; }
  .title { font-family: var(--display); font-weight: 600; font-size: 1.35rem; letter-spacing: -0.01em; }
  .tldr { font-size: 1.0625rem; color: #34322d; }
  .row { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; align-items: baseline; margin-top: 0.25rem; }
  .meta { font-family: var(--mono); font-size: 0.74rem; color: var(--muted); }
  .go { font-family: var(--mono); font-size: 0.74rem; color: var(--slate); }
  .card:hover .go { color: var(--loss); }
</style>
